FROM pytorch/pytorch:2.2.0-cuda12.1-cudnn8-runtime
WORKDIR /app
COPY requirements-gpu.txt .
RUN pip install --no-cache-dir -r requirements-gpu.txt
COPY . .
EXPOSE 8138
# Loopback by default (see Dockerfile). Override with OPENCOG_HOST=0.0.0.0 only behind your own controls.
CMD ["sh", "-c", "uvicorn sae_patch:app --host ${OPENCOG_HOST:-127.0.0.1} --port 8138"]
