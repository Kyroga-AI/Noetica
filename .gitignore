# Rust build artifacts
src-tauri/target/
embed-sidecar/target/
operator-sidecar/target/
# operator-sidecar's throwaway python env for the model-export recipe (torch/onnx)
operator-sidecar/.venv/

# Agent machine compiled output
agent-machine/dist/

# Sidecar binaries (downloaded at build time)
src-tauri/binaries/

# Tauri generated schemas
src-tauri/gen/
opencog-sidecar/__pycache__/
opencog-sidecar/cypher_gw/__pycache__/

# Python bytecode caches (anywhere) — e.g. agent-machine/scripts/__pycache__
__pycache__/
*.pyc

# bun --compile scratch files
*.bun-build
tsconfig.tsbuildinfo

# Per-user RUNTIME data — never commit or ship. This is the chat brain / self-model / identity /
# transcripts the app writes under ~/.noetica at runtime; a repo-local .noetica must never enter a
# build artifact (that is how a friend's install came preloaded with the developer's data).
/.noetica/

# Org profile is per-install runtime state, written to repo root by POST /api/identity/org
# (agent-machine/server.ts). Never commit — it would ship one org's config into every build.
/org-profile.json

# build artifacts (brain tarballs from package-brains.sh)
dist/
