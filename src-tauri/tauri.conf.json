{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Noetica",
  "version": "0.4.20",
  "identifier": "ai.noetica.app",
  "build": {
    "beforeDevCommand": "npm run dev -- --hostname 127.0.0.1 --port 3737",
    "devUrl": "http://127.0.0.1:3737",
    "beforeBuildCommand": "npm run build:static",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Noetica",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "packaging/macos/noetica.entitlements.plist",
      "signingIdentity": null,
      "providerShortName": null,
      "hardenedRuntime": true
    }
  }
}
