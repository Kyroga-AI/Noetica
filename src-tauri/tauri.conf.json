{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Noetica",
  "version": "0.1.0",
  "identifier": "ai.noetica.app",
  "build": {
    "beforeDevCommand": "npm run dev -- --hostname 127.0.0.1 --port 3737",
    "devUrl": "http://127.0.0.1:3737",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../.next"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Noetica",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": []
  }
}
