{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.org/schemas/memphis-promotion-gate.schema.json",
  "title": "Memphis Promotion Gate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "gateId",
    "candidateRef",
    "tierFrom",
    "tierTo",
    "approvedBy",
    "approvalStatus",
    "proofRefs",
    "rollbackPosture",
    "executionPerformed",
    "michaelApprovalRequired"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "gateId": {
      "type": "string",
      "minLength": 1
    },
    "candidateRef": {
      "type": "string",
      "minLength": 1
    },
    "tierFrom": {
      "type": "string",
      "enum": ["E1", "E2", "E3", "E4", "E5", "E6"]
    },
    "tierTo": {
      "type": "string",
      "enum": ["E1", "E2", "E3", "E4", "E5", "E6"]
    },
    "approvedBy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "approvalStatus": {
      "type": "string",
      "enum": ["proposed", "approved", "denied", "expired"]
    },
    "proofRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollbackPosture": {
      "type": "string"
    },
    "executionPerformed": {
      "type": "boolean",
      "const": false
    },
    "michaelApprovalRequired": {
      "type": "boolean"
    }
  },
  "if": {
    "properties": {
      "tierTo": {
        "enum": ["E5", "E6"]
      }
    }
  },
  "then": {
    "properties": {
      "michaelApprovalRequired": {
        "const": true
      }
    }
  }
}
