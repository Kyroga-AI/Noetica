{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.org/schemas/ofif-assurance-packet.schema.json",
  "title": "OFIF Assurance Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packetId",
    "clientScope",
    "tenantScope",
    "period",
    "postureSummaryRef",
    "coverageSummaryRefs",
    "proofDigestRefs",
    "validationRefs",
    "disclosureClass",
    "retentionPolicy",
    "signatures",
    "executionPerformed"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "0.1.0" },
    "packetId": {
      "type": "string",
      "pattern": "^ofif-assurance:[a-z0-9-]+$"
    },
    "clientScope": { "type": "string" },
    "tenantScope": { "type": "string" },
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" }
      }
    },
    "postureSummaryRef": { "type": "string", "minLength": 1 },
    "coverageSummaryRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "proofDigestRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "validationRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "disclosureClass": {
      "type": "string",
      "enum": ["internal", "client", "auditor", "public_redacted"]
    },
    "retentionPolicy": { "type": "string" },
    "signatures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["signedBy", "signedAt"],
        "properties": {
          "signedBy": { "type": "string" },
          "signedAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "executionPerformed": { "type": "boolean", "const": false }
  }
}
