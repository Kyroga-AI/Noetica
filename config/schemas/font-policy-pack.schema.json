{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.org/schemas/font-policy-pack.schema.json",
  "title": "Font Policy Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "policyId",
    "allowedActions",
    "prohibitedActions",
    "fingerprintMitigations",
    "syntheticOnly",
    "authorizationRef",
    "executionAllowed"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "policyId": {
      "type": "string",
      "pattern": "^font-policy:[a-z0-9-]+$"
    },
    "allowedActions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["observe", "report", "block", "substitute"]
      }
    },
    "prohibitedActions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "fingerprintMitigations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "syntheticOnly": {
      "type": "boolean"
    },
    "authorizationRef": {
      "type": "string",
      "minLength": 1
    },
    "executionAllowed": {
      "type": "boolean",
      "const": false
    }
  }
}
