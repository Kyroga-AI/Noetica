{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.org/schemas/promotion-pack.schema.json",
  "title": "Promotion Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "promotionPackId",
    "candidateRef",
    "tierFrom",
    "tierTo",
    "proofRefs",
    "rollbackPlanRef",
    "approvedBy",
    "approvalStatus",
    "evidenceSummary",
    "executionPerformed"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "promotionPackId": {
      "type": "string",
      "pattern": "^promotion-pack:[a-z0-9-]+$"
    },
    "candidateRef": {
      "type": "string",
      "minLength": 1
    },
    "tierFrom": {
      "type": "string",
      "enum": ["E1", "E2", "E3", "E4", "E5", "E6"]
    },
    "tierTo": {
      "type": "string",
      "enum": ["E1", "E2", "E3", "E4", "E5", "E6"]
    },
    "proofRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollbackPlanRef": {
      "type": "string",
      "minLength": 1
    },
    "approvedBy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "approvalStatus": {
      "type": "string",
      "enum": ["proposed", "approved", "denied", "expired"]
    },
    "evidenceSummary": {
      "type": "string"
    },
    "executionPerformed": {
      "type": "boolean",
      "const": false
    }
  }
}
