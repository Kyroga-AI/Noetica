{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.org/schemas/ofif-field-observation.schema.json",
  "title": "OFIF Field Observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "observationId",
    "sourceRunRef",
    "boundaryEventRefs",
    "surfaceRefs",
    "topicRefs",
    "summary",
    "confidence",
    "redactionState",
    "proofRefs",
    "disclosureClass",
    "clientScope",
    "tenantScope",
    "retentionPolicy",
    "sourceRunRefs",
    "executionPerformed"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "0.1.0" },
    "observationId": {
      "type": "string",
      "pattern": "^ofif-observation:[a-z0-9-]+$"
    },
    "sourceRunRef": { "type": "string", "minLength": 1 },
    "boundaryEventRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "surfaceRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "topicRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "summary": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "redactionState": {
      "type": "string",
      "enum": ["raw", "redacted", "synthetic", "withheld"]
    },
    "proofRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "disclosureClass": {
      "type": "string",
      "enum": ["internal", "client", "auditor", "public_redacted"]
    },
    "clientScope": { "type": "string" },
    "tenantScope": { "type": "string" },
    "retentionPolicy": { "type": "string" },
    "sourceRunRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "authorizationRef": { "type": "string", "minLength": 1 },
    "executionPerformed": { "type": "boolean", "const": false }
  }
}
