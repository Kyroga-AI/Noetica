{
  "name": "noetica",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "noetica": "cli/noetica.mjs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:static:probe": "node scripts/probe-static-export.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "smoke:standalone": "node scripts/smoke-standalone.mjs",
    "cli": "node cli/noetica.mjs",
    "cli:doctor": "node cli/noetica.mjs doctor --json",
    "cli:smoke": "node cli/noetica.mjs smoke --dry-run",
    "tauri:icon": "node scripts/ensure-tauri-icon.mjs",
    "tauri:dev": "npm run tauri:icon && tauri dev",
    "tauri:build": "npm run tauri:icon && tauri build"
  },
  "dependencies": {
    "next": "^14.2.23",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.23",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
