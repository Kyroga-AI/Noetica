{
  "name": "noetica",
  "version": "0.4.10",
  "private": true,
  "bin": {
    "noetica": "cli/noetica.mjs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:static": "NOETICA_STATIC_EXPORT=1 next build",
    "build:static:probe": "node scripts/probe-static-export.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "cd agent-machine && npm test",
    "icons:generate": "node scripts/generate-icons.mjs",
    "packaging:validate": "npm run icons:generate && node scripts/validate-packaging-metadata.mjs",
    "sourceos:events:export": "node scripts/export-sourceos-interaction-events.mjs",
    "sourceos:events:path": "node scripts/sourceos-event-export-path.mjs --json",
    "sourceos:events:path:check": "node scripts/check-sourceos-event-export-paths.mjs",
    "sourceos:events:risk-refs:check": "node scripts/validate-sourceos-risk-observatory-refs.mjs",
    "risk:score": "node scripts/score-risk-aversion.mjs",
    "risk:validate-fixtures": "node scripts/validate-risk-aversion-fixtures.mjs",
    "risk:validate-counterfactual": "node scripts/validate-counterfactual-risk-replay.mjs",
    "risk:counterfactual:report": "node scripts/generate-counterfactual-risk-report.mjs",
    "risk:graph": "node scripts/generate-risk-aversion-graph.mjs",
    "risk:path": "node scripts/risk-aversion-export-path.mjs --json",
    "risk:export": "node scripts/export-risk-aversion-traces.mjs",
    "smoke:standalone": "node scripts/smoke-standalone.mjs",
    "cli": "node cli/noetica.mjs",
    "cli:doctor": "node cli/noetica.mjs doctor --json",
    "cli:smoke": "node cli/noetica.mjs smoke --dry-run",
    "agent-machine": "cd agent-machine && npx tsx server.ts",
    "agent-machine:install": "cd agent-machine && npm install",
    "agent-machine:build": "cd agent-machine && npm install && npm run build",
    "agent-machine:build:binary": "bun build agent-machine/server.ts --compile --target bun-darwin-arm64 --outfile src-tauri/binaries/agent-machine-aarch64-apple-darwin && bun build agent-machine/server.ts --compile --target bun-darwin-x64 --outfile src-tauri/binaries/agent-machine-x86_64-apple-darwin",
    "agent-machine:build:binary:linux": "bun build agent-machine/server.ts --compile --target bun-linux-x64 --outfile src-tauri/binaries/agent-machine-x86_64-unknown-linux-gnu",
    "tauri": "tauri",
    "tauri:icon": "node scripts/ensure-tauri-icon.mjs",
    "tauri:dev": "npm run tauri:icon && tauri dev",
    "tauri:build": "npm run tauri:icon && tauri build",
    "tauri:build:static": "npm run tauri:icon && npm run build:static && tauri build",
    "tauri:build:full": "npm run agent-machine:build:binary && node scripts/inject-am-sidecar-config.mjs && npm run tauri:build:static && node scripts/inject-am-sidecar-config.mjs --restore"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@tauri-apps/api": "^2.0.0",
    "next": "^14.2.23",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "10.1.0",
    "react-syntax-highlighter": "16.1.1",
    "remark-gfm": "4.0.1",
    "zustand": "^5.0.2",
    "@socioprophet/hellgraph": "git+https://github.com/SocioProphet/hellgraph.git#v0.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/react-syntax-highlighter": "15.5.13",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.23",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
